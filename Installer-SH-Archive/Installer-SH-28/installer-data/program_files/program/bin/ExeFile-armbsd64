#!/usr/bin/env bash
# Script version 1.0

Args=("$@")
PathToScript="$( dirname "$(readlink -f "$0")")"

echo -e "Example Application! (armbsd64)\n"
echo -e "Path To Executable:\n $PathToScript\n"

echo -e "HOME:\n $HOME"
echo -e "XDG_DATA_HOME:\n $XDG_DATA_HOME"
echo -e "XDG_STATE_HOME:\n $XDG_STATE_HOME"
echo -e "XDG_CONFIG_HOME:\n $XDG_CONFIG_HOME"
echo -e "XDG_CACHE_HOME:\n $XDG_CACHE_HOME"
echo -e "PWD: $PWD"
echo -e "PATH: $PATH"
echo -e "LD_LIBRARY_PATH: $LD_LIBRARY_PATH"

for i in "${!Args[@]}"; do
	echo -e "${Args[$i]}"
done

read pause
